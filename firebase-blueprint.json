{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A project managed in the dashboard",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Project name" },
        "status": { "type": "string", "enum": ["ongoing", "upcoming", "regular", "issue", "completed"], "description": "Current status" },
        "taskCell": { "type": "string", "description": "Responsible cell" },
        "deadline": { "type": "string", "format": "date", "description": "Project deadline" },
        "startDate": { "type": "string", "format": "date", "description": "Start date" },
        "endDate": { "type": "string", "format": "date", "description": "End date" },
        "progress": { "type": "number", "description": "Progress percentage" },
        "pm": { "type": "string", "description": "Project Manager" },
        "assignees": { "type": "array", "items": { "type": "string" }, "description": "List of assignees" },
        "issues": { "type": "array", "items": { "type": "string" }, "description": "List of issues" },
        "tasks": { "type": "array", "items": { "type": "string" }, "description": "List of tasks" },
        "draftConfirmed": { "type": "boolean", "description": "Whether the draft is confirmed" },
        "attachments": { "type": "array", "items": { "type": "string" }, "description": "List of attachment URLs" },
        "uid": { "type": "string", "description": "Owner user ID" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "status", "uid", "createdAt"]
    },
    "TeamSchedule": {
      "title": "TeamSchedule",
      "description": "A team member's schedule entry (vacation, meeting, etc.)",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["vacation", "meeting", "seminar", "interview"], "description": "Type of schedule" },
        "subType": { "type": "string", "enum": ["annual", "half", "time"], "description": "Vacation subtype" },
        "title": { "type": "string", "description": "Schedule title" },
        "startDate": { "type": "string", "format": "date", "description": "Start date" },
        "endDate": { "type": "string", "format": "date", "description": "End date" },
        "time": { "type": "string", "description": "Time for time-off" },
        "participants": { "type": "array", "items": { "type": "string" }, "description": "List of participants" },
        "cell": { "type": "string", "description": "Team member's cell" },
        "uid": { "type": "string", "description": "Owner user ID" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["type", "title", "startDate", "endDate", "cell", "uid", "createdAt"]
    },
    "TeamMember": {
      "title": "TeamMember",
      "description": "A team member in the organization",
      "type": "object",
      "properties": {
        "index": { "type": "number", "description": "Index number" },
        "name": { "type": "string", "description": "Full name" },
        "rank": { "type": "string", "description": "Rank (직급)" },
        "role": { "type": "string", "description": "Role (직책)" },
        "cell": { "type": "string", "description": "Assigned cell" },
        "contact": { "type": "string", "description": "Phone number" },
        "email": { "type": "string", "format": "email", "description": "Email address" }
      },
      "required": ["index", "name", "rank", "role", "cell", "contact", "email"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of projects"
    },
    "/teamSchedules/{scheduleId}": {
      "schema": "TeamSchedule",
      "description": "Collection of team member schedules"
    },
    "/teamMembers/{memberId}": {
      "schema": "TeamMember",
      "description": "Collection of team members"
    }
  }
}
